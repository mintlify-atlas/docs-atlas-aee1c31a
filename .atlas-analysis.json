  "keyFeatures": [
    "Student management with enrollment plans",
    "Instructor and horse resource management",
    "Class scheduling and calendar operations",
    "Trial class system for prospects",
    "Multi-state class lifecycle (PROGRAMADA, INICIADA, COMPLETADA, CANCELADA, ACA, ASA)",
    "Horse boarding management (pension types)",
    "Authentication and user management with role-based access",
    "Comprehensive search and filtering"
  ],
  "publicApiSurface": [
    "POST /api/v1/auth/login",
    "POST /api/v1/auth/register",
    "GET /api/v1/alumnos",
    "POST /api/v1/alumnos",
    "PUT /api/v1/alumnos/{id}",
    "DELETE /api/v1/alumnos/{id}",
    "GET /api/v1/instructores",
